# Reference only — env vars are loaded per-service, not from this root file.
# Copy each block into the matching service's own .env (see the README):
#
#   backend/chatagent/.env.example  -> backend/chatagent/.env
#   backend/voiceagent/.env.example -> backend/voiceagent/.env

# --- backend/chatagent/.env ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- backend/voiceagent/.env ---
RETELL_API_KEY=key_your_retell_api_key_here
RETELL_AGENT_ID=agent_your_retell_agent_id_here
